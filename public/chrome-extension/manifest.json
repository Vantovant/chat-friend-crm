{
  "manifest_version": 3,
  "name": "Vanto CRM — WhatsApp Sidebar",
  "version": "1.1.0",
  "description": "Inject the Vanto CRM sidebar into WhatsApp Web for seamless lead management.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://nqyyvqcmcyggvlcswkio.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Vanto CRM",
    "default_popup": "popup.html"
  }
}
