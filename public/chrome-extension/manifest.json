{
  "manifest_version": 3,
  "name": "Vanto CRM — WhatsApp Sidebar",
  "version": "1.0.0",
  "description": "Inject the Vanto CRM sidebar into WhatsApp Web for seamless lead management.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Vanto CRM",
    "default_popup": "popup.html"
  }
}
